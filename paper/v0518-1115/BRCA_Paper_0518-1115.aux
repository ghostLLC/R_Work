\newlabel{fig:rules}{{12}{16}{关联规则散点图。横轴为Support（规则覆盖比例），纵轴为Confidence（条件概率），点的大小和颜色均编码Lift（$>1$=正关联）。右上角区域的规则兼具高Support和高Confidence，为最可靠的基因—临床特征关联。}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces miRNA-mRNA调控相关性热图（Top 20, $|r|>0.4$）。行=miRNA, 列=mRNA, 格内标注Pearson $r$值。红-白-蓝色阶：红色=正相关, 白色=无相关, 蓝色=负相关。蓝色格占主导, 符合miRNA抑制靶mRNA的调控预期。}}{17}{figure.caption.18}\protected@file@percent }
